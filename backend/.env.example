# ── Copy this file to .env and fill in your values ────────────────────────
# Never commit .env to version control.

# ── Application ────────────────────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-random-32-char-string-minimum

# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://spectre:spectre@localhost:5432/spectre
DATABASE_POOL_SIZE=10
DATABASE_ECHO=false

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── AWS / Storage ──────────────────────────────────────────────────────────
# Leave blank in development — reports save to /tmp instead
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=spectre-reports-dev

# ── LLM ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
LLM_JUDGE_MODEL=gpt-4o-mini
LLM_JUDGE_ENABLED=true

# ── Shield ─────────────────────────────────────────────────────────────────
SHIELD_POLICY_CACHE_TTL=30
SHIELD_MAX_INSPECTION_MS=30

# ── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
