# Spectre Security — Environment Variables
# Copy to .env and fill in your values.
# Required vars are marked [REQUIRED].
# Production-only vars are marked [PROD].

# ── Core ──────────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
SECRET_KEY=change-me-32-chars-minimum-generate-with-openssl  # [REQUIRED] openssl rand -hex 32
DEBUG=false                      # [PROD] Must be false in production

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://spectre:spectre@postgres:5432/spectre  # [REQUIRED]
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis / Celery ────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0                    # [REQUIRED]
CELERY_BROKER_URL=redis://redis:6379/1            # [REQUIRED]
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── CORS ──────────────────────────────────────────────────────────────────
# [PROD] Set to your actual frontend URL — never use * in production
ALLOWED_ORIGINS=["http://localhost:3000"]
# Production example:
# ALLOWED_ORIGINS=["https://app.spectresecurity.io"]

# ── Rate Limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_SCAN_CREATE=10/minute
RATE_LIMIT_AUTH_CREATE=5/minute
RATE_LIMIT_SHIELD_INSPECT=300/minute

# ── Shield ────────────────────────────────────────────────────────────────
SHIELD_POLICY_CACHE_TTL=30       # Seconds to cache policies in Redis
SHIELD_MAX_INSPECTION_MS=30      # Alert threshold for slow inspections
SHIELD_MAX_TEXT_LENGTH=50000     # Max chars per inspection request

# ── LLM Judge ────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...            # [REQUIRED if LLM_JUDGE_ENABLED=true]
LLM_JUDGE_ENABLED=false          # Set true to enable LLM-based classification
LLM_JUDGE_MODEL=gpt-4o-mini

# ── Reports / Storage ────────────────────────────────────────────────────
REPORT_FILES_DIR=/app/report_files
# AWS S3 (optional — local file fallback used if not set)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=
S3_REPORT_URL_EXPIRY=3600        # Signed URL expiry in seconds

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=pretty                # pretty (dev) | json (prod — auto-set in production)
